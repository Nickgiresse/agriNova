generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  nom       String
  prenom    String
  region    String?
  createdAt DateTime  @default(now())
  cultures  Culture[]
}

model Culture {
  id             String   @id @default(uuid())
  nom            String
  statut         String
  datePlantation DateTime
  surface        Float
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
}